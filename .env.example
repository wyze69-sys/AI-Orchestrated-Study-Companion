# ============================================================================
# AI-Orchestrated Study Companion — Environment Variables
# ============================================================================
# Copy this file to .env and fill in real values. Never commit .env.
# ============================================================================

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/study_companion

# JWT secret — must be at least 64 characters for security
JWT_SECRET=change-me-to-a-very-long-random-string-at-least-64-characters-long-1234567890

# Gemini AI API key from Google AI Studio (https://aistudio.google.com/apikey)
AI_INTEGRATIONS_GEMINI_API_KEY=

# Gemini API base URL (default works for most users)
AI_INTEGRATIONS_GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# API server port
PORT=5000
